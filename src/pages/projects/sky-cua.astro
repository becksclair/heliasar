		color: rgb(var(--accent));
	}

	.project-detail {
		padding-bottom: 2rem;
	}

	.eyebrow {
		margin-bottom: 0.5rem;
		color: var(--grey-mid);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.85rem;
	}

	h1 {
		font-size: 2.4rem;
		margin-top: 0;
	}

	.lede {
		font-size: 1.2rem;
		color: var(--color-fg-copy);
	}
</style>
