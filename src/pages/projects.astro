---
import Card from "../components/Card.astro";
import Layout from "../layouts/Layout.astro";

const projects = [
	{
		title: "sky-cua",
		body: "A cross-platform computer-use platform for AI agents, spanning desktop automation, browser control, Android integration, diagnostics, and MCP host packaging.",
		href: "/projects/sky-cua/",
	},
	{
		title: "EMEET PIXY Controller",
		body: "A reverse-engineered USB camera automation platform with native Linux tooling, browser controls, diagnostics, protocol replay, and live-preview enhancement design.",
		href: "/projects/emeet-pixy-controller/",
	},
	{
		title: "Voyager Golden Record Explorer",
		body: "A Rust/egui signal-processing application for recovering NASA Voyager Golden Record images from audio, with diagnostics, export, and responsive visual exploration.",
		href: "/projects/voyager-golden-record-explorer/",
	},
];
---

<Layout
	title="Projects"
	description="Selected software projects by Rebecca Clair — AI-agent infrastructure, native automation, reverse engineering, and signal-processing tools."
>
	<main>
		<h1>Projects</h1>
		<div class="content intro">
			<p>
				Selected engineering projects with more room to breathe than a resume allows:
				the systems work, architecture decisions, reverse engineering, diagnostics,
				and platform thinking behind them.
			</p>
			<p>
				You can also find my open-source work on <a
					href="https://github.com/becksClair"
					target="_blank"
					rel="noopener noreferrer">GitHub</a
				>.
			</p>
		</div>
		<ul class="link-card-grid">
			{
				projects.map((project) => (
					<Card title={project.title} body={project.body} href={project.href} />
				))
			}
		</ul>
	</main>
</Layout>

<style lang="scss">
	h1 {
		text-align: center;
		padding-top: 1rem;
		padding-bottom: 1rem;
		font-size: 2rem;
	}

	.intro {
		margin-bottom: 1.5rem;

		& a {
			color: rgb(var(--accent));
		}
	}

	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(28ch, 1fr));
		gap: 1rem;
		padding: 0;
		margin: 0;
	}
</style>
