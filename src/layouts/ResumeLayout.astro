---
import "../styles/styles.scss";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
---

<Layout title="Resume" description={frontmatter.description}>
	<main>
		<div class="resume-header">
			<div class="resume-heading">
				<p class="page-eyebrow">Experience · selected work · capabilities</p>
				<h1>Resume</h1>
			</div>
			<div class="resume-actions" aria-label="Resume actions">
				<a class="site-btn primary" href="/Rebecca_Clair_Resume.pdf" download>
					Download resume
				</a>
				<a class="site-btn" href="mailto:rebecca@heliasar.com">Contact</a>
			</div>
		</div>
		<div class="content">
			{
				frontmatter.image && (
					<div class="post-image-container">
						<img
							class="post-img shadow-img"
							loading="lazy"
							src={frontmatter.image.url}
							height="300"
							alt={frontmatter.image.alt}
						/>
					</div>
				)
			}
			<slot />
		</div>
	</main>
</Layout>

<style lang="scss">
	.resume-header {
		display: flex;
		max-width: 1120px;
		align-items: flex-end;
		justify-content: space-between;
		gap: 2rem;
		margin: 0 auto 1.5rem;
	}

	.resume-heading {
		min-width: 0;

		.page-eyebrow {
			margin-bottom: 0.75rem;
		}

		h1 {
			margin: 0 !important;
			padding: 0 !important;
			font-size: clamp(1.75rem, 2vw, 2rem) !important;
			line-height: 1 !important;
		}
	}

	.resume-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: flex-end;
		margin: 0;

		.primary {
			border-color: transparent;
			color: white;
			background: linear-gradient(100deg, var(--accent-color), var(--pink));
		}
	}

	main .content {
		max-width: 1120px;
		margin: 0 auto;

		:global(a) {
			font-weight: 650;
		}

		:global(h3) {
			font-size: 1.1rem !important;
			line-height: 1.25;
		}

		:global(h2:first-of-type) {
			margin-top: 0;
		}
	}
	.post-image-container {
		float: left;
		margin-right: 2.25rem;
		margin-bottom: 1rem;
		margin-top: 0;
	}
	.post-img {
		display: block;
		height: 170px;
		width: auto;
		margin: 0;

		@media (max-width: 700px) {
			height: 192px;
		}
	}

	@media (max-width: 700px) {
		.resume-header {
			align-items: flex-start;
			flex-direction: column;
			gap: 1.25rem;
		}

		.resume-actions {
			width: 100%;
			justify-content: flex-start;

		}
	}
</style>
