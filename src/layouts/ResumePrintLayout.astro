---
const { frontmatter } = Astro.props;
const image = frontmatter.image;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<title>{frontmatter.title} — Resume PDF</title>
	</head>
	<body>
		<main class="resume-page">
			<header class="resume-header">
				<div class="resume-title">
					<h1>{frontmatter.title}</h1>
					<p>{frontmatter.subtitle}</p>
				</div>
				{image && <img class="headshot" src={image.url} alt={image.alt} />}
			</header>
			<section class="resume-content">
				<slot />
			</section>
		</main>
		<script is:inline>
			const content = document.querySelector(".resume-content");
			if (content) {
				for (const paragraph of [...content.querySelectorAll(":scope > p")]) {
					if (paragraph.textContent?.trim().startsWith("→ Full write-up")) {
						paragraph.remove();
					}
				}

				for (const heading of [...content.querySelectorAll(":scope > h3")]) {
					const entry = document.createElement("section");
					entry.className = "resume-entry";
					heading.before(entry);

					let node = heading;
					while (node && !(node !== heading && node.matches?.("h2, h3"))) {
						const next = node.nextElementSibling;
						entry.append(node);
						node = next;
					}
				}
			}
		</script>
	</body>
</html>

<style is:global>
	@page {
		size: A4;
		margin: 10mm 12mm;
	}

	:root {
		--resume-accent: #0b4f6a;
		--resume-text: #111111;
		--resume-muted: #24323a;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: white;
		color: var(--resume-text);
		font-family: Arial, Helvetica, sans-serif;
		font-size: 8.85pt;
		line-height: 1.14;
	}

	.resume-page {
		width: 100%;
		max-width: none;
		margin: 0;
		padding: 0;
	}

	.resume-header {
		display: grid;
		grid-template-columns: 1fr 31mm;
		gap: 12mm;
		align-items: start;
		min-height: 31mm;
		margin-bottom: 2.8mm;
		break-after: avoid;
	}

	.resume-title h1 {
		margin: 1.5mm 0 3mm;
		color: var(--resume-accent);
		font-size: 18.5pt;
		font-weight: 400;
		line-height: 1;
	}

	.resume-title p {
		margin: 0;
		font-size: 10.5pt;
		font-weight: 700;
		font-style: italic;
		line-height: 1.2;
	}

	.headshot {
		width: 30mm;
		height: 30mm;
		margin-top: 0;
		border-radius: 8px;
		object-fit: cover;
		object-position: 52% 28%;
		box-shadow: 0 3px 12px rgba(0, 0, 0, 0.28);
	}

	.resume-content h2 {
		margin: 3.8mm 0 1.4mm;
		color: var(--resume-accent);
		font-size: 12.8pt;
		font-weight: 400;
		line-height: 1.1;
		break-after: avoid;
	}

	.resume-content h2:first-child {
		margin-top: 0;
	}

	.resume-content h3 {
		margin: 3.2mm 0 1mm;
		color: var(--resume-accent);
		font-size: 10.2pt;
		font-weight: 400;
		line-height: 1.12;
		break-after: avoid;
	}

	.resume-content h4 {
		margin: 0 0 1.1mm;
		color: var(--resume-accent);
		font-size: 10pt;
		font-weight: 400;
		font-style: italic;
		line-height: 1.15;
		text-transform: uppercase;
		break-after: avoid;
	}

	.resume-content p {
		margin: 0 0 1.5mm;
		font-size: 8.9pt;
		line-height: 1.14;
	}

	.resume-content h2:last-of-type ~ p {
		margin-bottom: 0.7mm;
		font-size: 8.2pt;
		line-height: 1.05;
	}

	.resume-content a {
		color: var(--resume-accent);
		text-decoration: none;
	}

	.resume-content hr {
		display: none;
	}

	.resume-content ul {
		margin: 0 0 1mm 0;
		padding-left: 0;
		list-style: none;
		break-inside: avoid;
	}

	.resume-content li {
		position: relative;
		margin: 0 0 0.08mm 0;
		padding-left: 3.2mm;
		font-size: 8.7pt;
		line-height: 1.08;
		break-inside: avoid;
	}

	.resume-content li > p {
		margin: 0;
		font-size: inherit;
		line-height: inherit;
	}

	.resume-content li::before {
		content: "•";
		position: absolute;
		left: 0.65mm;
		top: 0;
		font-size: 8.7pt;
		line-height: 1.08;
	}

	.resume-content strong {
		font-weight: 700;
	}

	.resume-entry {
		break-inside: avoid;
	}

	.resume-content h3,
	.resume-content h4,
	.resume-content h3 + h4,
	.resume-content h4 + ul {
		break-inside: avoid;
	}

	.resume-content h3,
	.resume-content h4 {
		page-break-after: avoid;
	}

	.resume-content h3 + h4,
	.resume-content h4 + p,
	.resume-content h4 + ul {
		page-break-before: avoid;
	}

	.resume-content h2 + *,
	.resume-content h3 + *,
	.resume-content h4 + * {
		break-before: avoid;
	}

	@media screen {
		body {
			background: #e8e8e8;
		}

		.resume-page {
			width: 210mm;
			min-height: 297mm;
			margin: 12mm auto;
			padding: 12mm 14mm 12mm;
			background: white;
			box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18);
		}
	}
</style>
