---
export interface Props {
	title: string;
	svg: string;
	caption?: string;
}

const { title, svg, caption } = Astro.props;
---

<figure class="mermaid-diagram">
	<figcaption>
		<strong>{title}</strong>
		{caption && <span>{caption}</span>}
	</figcaption>
	<div class="mermaid-diagram__chart" set:html={svg} />
</figure>

<style lang="scss">
	.mermaid-diagram {
		margin: 1.75rem 0;
		padding: 1rem;
		border: 1px solid rgba(var(--accent), 24%);
		border-radius: var(--border-radius-base);
		background: linear-gradient(180deg, #fff, #fff7ff);
		overflow-x: auto;

		figcaption {
			display: grid;
			gap: 0.25rem;
			margin-bottom: 0.75rem;
			color: var(--color-fg-copy);
			font-size: 0.95rem;

			strong {
				color: var(--black);
				font-family: Chicago, sans-serif;
				font-size: 1rem;
			}
		}
	}

	.mermaid-diagram__chart {
		margin: 0;
		padding: 0.5rem;
		background: transparent;
		text-align: center;

		svg {
			max-width: 100%;
			height: auto;
		}
	}
</style>
