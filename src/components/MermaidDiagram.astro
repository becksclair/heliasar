---
import "@phosphor-icons/web/regular";

export interface Props {
	title: string;
	svg: string;
	caption?: string;
}

const { title, svg, caption } = Astro.props;
const diagramId =
	svg.match(/<svg[^>]+id="([^"]+)"/)?.[1] ??
	`diagram-${title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
---

<figure class="mermaid-diagram" data-diagram>
	<figcaption id={`${diagramId}-caption`}>
		<strong>{title}</strong>
		{caption && <span>{caption}</span>}
	</figcaption>
	<div class="mermaid-diagram__preview">
		<button
			class="diagram-control diagram-control--expand"
			type="button"
			data-diagram-open
			aria-label={`Open ${title} diagram viewer`}
		>
			<i class="ph ph-arrows-out" aria-hidden="true"></i>
			<span>Expand</span>
		</button>
		{/* The figcaption names the figure; the SVG itself is decorative. */}
		<div class="mermaid-diagram__home" data-diagram-home>
			<div class="mermaid-diagram__chart" aria-hidden="true" data-diagram-canvas set:html={svg} />
		</div>
	</div>

	<dialog
		class="diagram-viewer"
		data-diagram-dialog
		aria-labelledby={`${diagramId}-viewer-title`}
	>
		<div class="diagram-viewer__shell">
			<h2 id={`${diagramId}-viewer-title`} class="visually-hidden">{title} diagram viewer</h2>
			<div class="diagram-viewer__toolbar" aria-label="Diagram controls">
				<button class="diagram-control" type="button" data-diagram-zoom-out aria-label="Zoom out">
					<i class="ph ph-minus" aria-hidden="true"></i>
				</button>
				<span class="diagram-viewer__scale" data-diagram-scale aria-live="polite">100%</span>
				<button class="diagram-control" type="button" data-diagram-zoom-in aria-label="Zoom in">
					<i class="ph ph-plus" aria-hidden="true"></i>
				</button>
				<button class="diagram-control" type="button" data-diagram-reset aria-label="Reset view">
					<i class="ph ph-corners-in" aria-hidden="true"></i>
					<span>Reset</span>
				</button>
			</div>
			<p class="diagram-viewer__hint">Scroll to zoom · drag to move</p>
			<button class="diagram-control diagram-viewer__close" type="button" data-diagram-close aria-label="Close diagram viewer">
				<i class="ph ph-x" aria-hidden="true"></i>
			</button>
			<div class="diagram-viewer__stage" data-diagram-stage></div>
		</div>
	</dialog>
</figure>

<style lang="scss">
	.mermaid-diagram {
		margin: 2.5rem 0 3rem;
		padding: 0;

		figcaption {
			display: grid;
			gap: 0.35rem;
			margin-bottom: 1rem;
			color: var(--color-fg-copy);
			font-size: 0.95rem;

			strong {
				color: var(--color-fg);
				font-family: Chicago, sans-serif;
				font-size: 1rem;
			}
		}
	}

	.mermaid-diagram__preview {
		position: relative;
		height: clamp(19rem, 42vw, 28rem);
		border-block: 1px solid var(--line);
		background: color-mix(in srgb, var(--page-surface-solid) 62%, transparent);
		overflow: hidden;
	}

	.mermaid-diagram__home {
		display: grid;
		width: 100%;
		height: 100%;
		min-width: 0;
		min-height: 0;
		place-items: center;
		overflow: hidden;
	}

	.mermaid-diagram__chart {
		display: grid;
		width: 100%;
		height: 100%;
		min-width: 0;
		min-height: 0;
		padding: 3.4rem 1rem 1.5rem;
		place-items: center;
		overflow: hidden;

		:global(svg) {
			display: block;
			width: 100%;
			height: 100%;
			max-width: none !important;
			touch-action: none;
		}
	}

	.mermaid-diagram :global(svg .messageText),
	.mermaid-diagram :global(svg .labelText),
	.mermaid-diagram :global(svg .loopText),
	.mermaid-diagram :global(svg .noteText),
	.mermaid-diagram :global(svg .sequenceNumber) {
		fill: var(--color-fg-copy) !important;
	}

	.mermaid-diagram :global(svg .messageLine0),
	.mermaid-diagram :global(svg .messageLine1),
	.mermaid-diagram :global(svg .actor-line),
	.mermaid-diagram :global(svg .loopLine) {
		stroke: color-mix(in srgb, var(--color-fg-copy) 74%, rgb(var(--accent))) !important;
	}

	.diagram-control {
		display: inline-flex;
		min-width: 1.85rem;
		height: 1.85rem;
		padding: 0 0.5rem;
		border: 1px solid var(--line);
		border-radius: 0.4rem;
		align-items: center;
		justify-content: center;
		gap: 0.3rem;
		background: var(--page-surface-solid);
		box-shadow: none;
		color: var(--color-fg);
		font: 700 0.68rem/1 var(--font-family-mono);
		cursor: pointer;
		transition:
			border-color var(--global-transition-time),
			background var(--global-transition-time),
			color var(--global-transition-time),
			transform 90ms ease;

		&:hover {
			border-color: rgb(var(--accent));
			color: rgb(var(--accent));
		}

		&:active {
			transform: translateY(1px);
		}

		&:focus-visible {
			outline: 2px solid rgb(var(--accent));
			outline-offset: 3px;
		}

		i {
			font-size: 0.85rem;
		}
	}

	.diagram-control--expand {
		position: absolute;
		top: 0.65rem;
		left: 0.65rem;
		z-index: 2;
		background: color-mix(in srgb, var(--page-surface-solid) 92%, transparent);
		backdrop-filter: blur(8px);
	}

	.diagram-viewer {
		width: calc(100vw - 3rem);
		max-width: none;
		height: calc(100dvh - 3rem);
		max-height: none;
		margin: auto;
		padding: 0;
		border: 1px solid color-mix(in srgb, rgb(var(--accent)) 45%, var(--line));
		border-radius: 0.75rem;
		background: var(--page-surface-solid);
		box-shadow: 0 1.5rem 5rem rgb(0 0 0 / 42%);
		color: var(--color-fg);
		overflow: hidden;

		&::backdrop {
			background: rgb(6 3 10 / 82%);
			backdrop-filter: blur(5px);
		}
	}

	.diagram-viewer__shell {
		position: relative;
		width: 100%;
		height: 100%;
		background:
			linear-gradient(var(--line) 1px, transparent 1px),
			linear-gradient(90deg, var(--line) 1px, transparent 1px),
			var(--page-surface-solid);
		background-size: 32px 32px;
	}

	.diagram-viewer__toolbar {
		position: absolute;
		top: 0.75rem;
		left: 0.75rem;
		z-index: 3;
		display: flex;
		align-items: center;
		gap: 0.3rem;
	}

	.diagram-viewer__scale {
		display: inline-grid;
		min-width: 2.75rem;
		height: 1.85rem;
		padding-inline: 0.4rem;
		border-block: 1px solid var(--line);
		place-items: center;
		color: var(--color-fg-copy);
		font: 700 0.65rem/1 var(--font-family-mono);
		font-variant-numeric: tabular-nums;
	}

	.diagram-viewer__hint {
		position: absolute;
		bottom: 1rem;
		left: 50%;
		z-index: 3;
		margin: 0;
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: color-mix(in srgb, var(--page-surface-solid) 90%, transparent);
		color: var(--color-fg-copy);
		font-size: 0.75rem;
		transform: translateX(-50%);
		pointer-events: none;
	}

	.diagram-viewer__close {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		z-index: 3;
	}

	.diagram-viewer__stage {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		overflow: hidden;
		cursor: grab;

		&:active {
			cursor: grabbing;
		}

		.mermaid-diagram__chart {
			padding: 5rem 4rem 3.5rem;
		}
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		border: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0 0 0 0);
		white-space: nowrap;
	}

	@media (max-width: 700px) {
		.mermaid-diagram__preview {
			height: 20rem;
		}

		.diagram-viewer {
			width: 100vw;
			height: 100dvh;
			border: 0;
			border-radius: 0;
		}

		.diagram-viewer__stage .mermaid-diagram__chart {
			padding: 4.5rem 1rem 3.5rem;
		}

		.diagram-viewer__hint {
			display: none;
		}
	}
</style>

<script>
	import Panzoom from "@panzoom/panzoom";

	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

	document.querySelectorAll<HTMLElement>("[data-diagram]").forEach((figure) => {
		if (figure.dataset.initialized === "true") return;
		figure.dataset.initialized = "true";

		const dialog = figure.querySelector<HTMLDialogElement>("[data-diagram-dialog]");
		const home = figure.querySelector<HTMLElement>("[data-diagram-home]");
		const stage = figure.querySelector<HTMLElement>("[data-diagram-stage]");
		const canvas = figure.querySelector<HTMLElement>("[data-diagram-canvas]");
		const openButton = figure.querySelector<HTMLButtonElement>("[data-diagram-open]");
		const closeButton = figure.querySelector<HTMLButtonElement>("[data-diagram-close]");
		const zoomInButton = figure.querySelector<HTMLButtonElement>("[data-diagram-zoom-in]");
		const zoomOutButton = figure.querySelector<HTMLButtonElement>("[data-diagram-zoom-out]");
		const resetButton = figure.querySelector<HTMLButtonElement>("[data-diagram-reset]");
		const scaleLabel = figure.querySelector<HTMLElement>("[data-diagram-scale]");

		if (!dialog || !home || !stage || !canvas || !openButton || !closeButton || !zoomInButton || !zoomOutButton || !resetButton || !scaleLabel) return;

		let panzoom: ReturnType<typeof Panzoom> | undefined;
		let wheelHandler: ((event: WheelEvent) => void) | undefined;
		let scaleHandler: ((event: Event) => void) | undefined;

		const updateScale = (scale: number) => {
			scaleLabel.textContent = `${Math.round(scale * 100)}%`;
		};

		const restoreDiagram = () => {
			const svg = canvas.querySelector<SVGElement>("svg");
			if (wheelHandler) stage.removeEventListener("wheel", wheelHandler);
			if (svg && scaleHandler) svg.removeEventListener("panzoomchange", scaleHandler);
			panzoom?.destroy();
			panzoom = undefined;
			wheelHandler = undefined;
			scaleHandler = undefined;
			if (svg) {
				svg.style.removeProperty("transform");
				svg.style.removeProperty("transform-origin");
			}
			home.append(canvas);
			updateScale(1);
		};

		openButton.addEventListener("click", () => {
			stage.append(canvas);
			dialog.showModal();
			const svg = canvas.querySelector<SVGElement>("svg");
			if (!svg) return;

			panzoom = Panzoom(svg, {
				animate: !prefersReducedMotion.matches,
				canvas: true,
				maxScale: 6,
				minScale: 0.65,
				panOnlyWhenZoomed: true,
				step: 0.25,
			});
			wheelHandler = panzoom.zoomWithWheel;
			stage.addEventListener("wheel", wheelHandler, { passive: false });
			scaleHandler = (event) => {
				updateScale((event as CustomEvent<{ scale: number }>).detail.scale);
			};
			svg.addEventListener("panzoomchange", scaleHandler);
		});

		closeButton.addEventListener("click", () => dialog.close());
		zoomInButton.addEventListener("click", () => panzoom?.zoomIn());
		zoomOutButton.addEventListener("click", () => panzoom?.zoomOut());
		resetButton.addEventListener("click", () => panzoom?.reset({ animate: !prefersReducedMotion.matches }));
		dialog.addEventListener("click", (event) => {
			if (event.target === dialog) dialog.close();
		});
		dialog.addEventListener("close", restoreDiagram);
	});
</script>
