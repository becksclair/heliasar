---
export interface Props {
	title: string;
	svg: string;
	caption?: string;
}

const { title, svg, caption } = Astro.props;
---

<figure class="mermaid-diagram">
	<figcaption>
		<strong>{title}</strong>
		{caption && <span>{caption}</span>}
	</figcaption>
	{/* The figcaption names the figure; the SVG itself is decorative. */}
	<div class="mermaid-diagram__chart" aria-hidden="true" set:html={svg} />
</figure>

<style lang="scss">
	.mermaid-diagram {
		margin: 1.75rem 0;
		padding: 1.25rem;
		border: 1px solid var(--line);
		border-radius: var(--border-radius-base);
		background: linear-gradient(145deg, color-mix(in srgb, var(--accent-color) 7%, var(--page-surface-solid)), var(--page-surface-solid));
		overflow-x: auto;
		box-shadow: var(--shadow-soft);

		figcaption {
			display: grid;
			gap: 0.25rem;
			margin-bottom: 0.75rem;
			color: var(--color-fg-copy);
			font-size: 0.95rem;

			strong {
				color: var(--color-fg);
				font-family: Chicago, sans-serif;
				font-size: 1rem;
			}
		}
	}

	.mermaid-diagram__chart {
		margin: 0;
		padding: 0.5rem;
		background: transparent;
		text-align: center;

		svg {
			max-width: 100%;
			height: auto;
		}
	}
</style>
