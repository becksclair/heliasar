---
export interface Props {
	title: string;
	body: string;
	href: string;
	icon: string;
	label: string;
}

const { href, title, body, icon, label } = Astro.props;
---

<li class="link-card">
	<a href={href}>
		<div class="card-header">
			<div class="card-heading">
				<p class="card-label">{label}</p>
				<h3>{title}</h3>
			</div>
			<span class="icon-frame" aria-hidden="true">
				<i class={`ph ${icon}`}></i>
			</span>
		</div>
		<p class="card-copy">{body}</p>
	</a>
</li>

<style>
	.link-card {
		--card-frame: var(--line);
		--card-surface: color-mix(
			in srgb,
			var(--page-surface-solid) 78%,
			transparent
		);
		--card-copy: var(--color-fg-copy);
		--card-hover-mid: var(--pink);
		--card-hover-end: var(--page-surface-solid);

		position: relative;
		display: flex;
		min-width: 0;
		min-height: 11.5rem;
		padding: 1px;
		overflow: hidden;
		border-radius: 1.1rem;
		background-color: var(--card-frame);
		background-position: 100%;
		background-size: 400%;
		box-shadow: var(--shadow-soft);
		list-style: none;
		transition:
			background-position 0.6s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow var(--global-transition-time),
			transform var(--global-transition-time);
	}

	.link-card > a {
		display: flex;
		width: 100%;
		min-width: 0;
		flex-direction: column;
		border-radius: calc(1.1rem - 1px);
		padding: 1.35rem;
		color: var(--color-fg);
		background: var(--card-surface);
		text-decoration: none;
	}

	.card-header {
		display: flex;
		margin-bottom: 0.8rem;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.card-heading {
		min-width: 0;
	}

	.icon-frame {
		display: grid;
		width: 2.75rem;
		height: 2.75rem;
		flex: 0 0 2.75rem;
		place-items: center;
		border: 1px solid var(--line-strong);
		border-radius: 0.8rem;
		color: var(--accent-strong);
		background: color-mix(
			in srgb,
			var(--accent-color) 8%,
			var(--page-surface-solid)
		);
		font-size: 1.35rem;
		transition:
			border-color var(--global-transition-time),
			color var(--global-transition-time),
			background var(--global-transition-time);
	}

	.card-label {
		margin: 0 0 0.3rem;
		color: var(--pink);
		font-size: 0.68rem;
		font-weight: 850;
		letter-spacing: 0.14em;
		line-height: 1.2;
		text-transform: uppercase;
	}

	h3 {
		min-width: 0;
		margin: 0;
		color: var(--color-fg);
		font-size: 1.18rem;
		line-height: 1.15;
		transition: color var(--global-transition-time);
	}

	.card-copy {
		margin: 0;
		color: var(--card-copy);
		font-size: 0.9rem;
		line-height: 1.55;
	}

	.link-card:is(:hover, :focus-within) {
		background-image: linear-gradient(
			45deg,
			rgb(var(--accent)),
			var(--card-hover-mid) 35%,
			var(--card-hover-end) 70%
		);
		background-position: 0;
		box-shadow: var(--shadow);
		transform: translateY(-3px);
	}

	.link-card:is(:hover, :focus-within) .icon-frame {
		border-color: color-mix(in srgb, var(--pink) 55%, var(--line-strong));
		color: var(--pink);
		background: color-mix(
			in srgb,
			var(--pink) 10%,
			var(--page-surface-solid)
		);
	}

	@media (prefers-color-scheme: dark) {
		.link-card {
			--card-surface: color-mix(
				in srgb,
				var(--page-surface-solid) 90%,
				transparent
			);
			--card-hover-end: #24172f;
		}
	}

	@media (max-width: 640px) {
		.link-card {
			min-height: 0;
		}

		.link-card > a {
			padding: 1.2rem;
		}
	}
</style>
