---
const pathname = Astro.url.pathname;
const links = [
	{ href: "/", label: "Home" },
	{ href: "/resume", label: "Resume" },
	{ href: "/projects", label: "Projects" },
];

const isActive = (href: string) =>
	href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<nav class="navbar">
	<div class="navbar-inner">
		<a class="navbar-logo" href="/" aria-label="Heliasar home">
			<span>HELIASAR</span><i aria-hidden="true">/</i><strong>REBECCA CLAIR</strong>
		</a>
		<ul class="navbar-links" id="navbar-links">
			{
				links.map((link) => (
					<li>
						<a
							href={link.href}
							class:list={{ active: isActive(link.href) }}
							aria-current={isActive(link.href) ? "page" : undefined}
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
		<button
			type="button"
			class="navbar-toggle"
			aria-label="Toggle navigation menu"
			aria-expanded="false"
			aria-controls="navbar-links"
		>
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>
</nav>

<script>
	const navbarToggle = document.querySelector(".navbar-toggle");
	const navbarLinks = document.querySelector(".navbar-links");
	const desktopQuery = window.matchMedia("(min-width: 769px)");

	navbarToggle?.addEventListener("click", () => {
		const isOpen = navbarLinks?.classList.toggle("active") ?? false;
		navbarToggle?.classList.toggle("active");
		navbarToggle?.setAttribute("aria-expanded", String(isOpen));
	});

	navbarLinks?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => {
			navbarLinks.classList.remove("active");
			navbarToggle?.classList.remove("active");
			navbarToggle?.setAttribute("aria-expanded", "false");
		});
	});

	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			navbarLinks?.classList.remove("active");
			navbarToggle?.classList.remove("active");
			navbarToggle?.setAttribute("aria-expanded", "false");
		}
	});

	// On desktop the links are always shown via CSS, so reset the toggle state
	// when crossing the breakpoint to keep aria-expanded from going stale.
	desktopQuery.addEventListener("change", (event) => {
		if (event.matches) {
			navbarLinks?.classList.remove("active");
			navbarToggle?.classList.remove("active");
			navbarToggle?.setAttribute("aria-expanded", "false");
		}
	});
</script>

<style lang="scss">
	.navbar {
		position: sticky;
		top: 0;
		z-index: 1000;
		width: 100%;
		border-bottom: 1px solid var(--line);
		background: color-mix(in srgb, var(--page-canvas) 86%, transparent);
		backdrop-filter: blur(18px);
	}

	.navbar-inner {
		display: flex;
		width: min(var(--global-max-width), calc(100% - 40px));
		min-height: 64px;
		margin: 0 auto;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}

	.navbar-logo {
		display: inline-flex;
		align-items: baseline;
		gap: 0.55rem;
		color: var(--color-fg);
		font-family: var(--font-family-display);
		font-size: 0.92rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-decoration: none;
		white-space: nowrap;

		i {
			color: var(--pink);
			font-family: var(--font-family-body);
			font-style: normal;
		}

		strong {
			color: var(--pink);
			font-weight: inherit;
		}
	}

	.navbar-links {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.navbar-links a {
		display: inline-flex;
		min-height: 38px;
		align-items: center;
		border-radius: 999px;
		padding: 0.45rem 0.85rem;
		color: var(--grey-mid);
		font-family: var(--font-family-body);
		font-size: 0.88rem;
		font-weight: 750;
		text-decoration: none;
		transition: color var(--global-transition-time), background var(--global-transition-time), transform var(--global-transition-time);

		&:hover,
		&:focus-visible,
		&.active {
			color: var(--color-fg);
			background: color-mix(in srgb, var(--accent-color) 14%, transparent);
		}

		&:hover {
			transform: translateY(-1px);
		}
	}

	.navbar-toggle:focus-visible,
	.navbar-links a:focus-visible {
		outline: 2px solid var(--color-focus-outline);
		outline-offset: 2px;
		border-radius: 999px;
	}

	.navbar-toggle {
		display: none;
		cursor: pointer;
		appearance: none;
		width: 42px;
		height: 42px;
		border: 1px solid var(--line);
		border-radius: 999px;
		padding: 9px;
		background: var(--page-surface);
		margin: 0;
	}

	.navbar-toggle span {
		display: block;
		width: 22px;
		height: 2px;
		border-radius: 99px;
		background-color: var(--pink);
		margin: 4px 0;
		transition: transform var(--global-transition-time), opacity var(--global-transition-time);
	}

	@media (max-width: 768px) {
		.navbar-links {
			display: none;
		}

		.navbar-toggle {
			display: block;
		}

		.navbar-toggle.active span:nth-child(2) {
			opacity: 0;
		}

		.navbar-toggle.active span:nth-child(1) {
			transform: rotate(45deg) translate(4px, 4px);
		}

		.navbar-toggle.active span:nth-child(3) {
			transform: rotate(-45deg) translate(4px, -4px);
		}

		.navbar-links.active {
			z-index: 1001;
			display: flex;
			flex-direction: column;
			align-items: stretch;
			position: absolute;
			top: calc(100% + 8px);
			right: 12px;
			width: min(260px, calc(100vw - 24px));
			border: 1px solid var(--line);
			border-radius: 1.25rem;
			padding: 0.7rem;
			background: var(--page-surface-solid);
			box-shadow: var(--shadow-soft);
		}

		.navbar-links.active a {
			display: flex;
			width: 100%;
			justify-content: center;
		}

		.navbar-inner {
			position: relative;
			width: calc(100% - 24px);
			min-height: 58px;
		}

		.navbar-logo {
			font-size: 0.78rem;
			gap: 0.4rem;
		}
	}
</style>
