---
---

<nav class="navbar">
	<div class="navbar-logo">
		<a href="/">
			<p class="navbar-logo-text">
				<span class="text-gradient">Rebecca Clair</span>
			</p>
		</a>
	</div>
	<ul class="navbar-links" id="navbar-links">
		<li>
			<a href="/">Home</a>
		</li>
		<li>
			<a href="/resume">Resume</a>
		</li>
		<li>
			<a href="/projects">Projects</a>
		</li>
		<li>
			<a href="/blog">Blog</a>
		</li>
	</ul>
	<button
		type="button"
		class="navbar-toggle"
		aria-label="Toggle navigation menu"
		aria-expanded="false"
		aria-controls="navbar-links"
	>
		<span></span>
		<span></span>
		<span></span>
	</button>
</nav>

<script>
	const navbarToggle = document.querySelector(".navbar-toggle");
	const navbarLinks = document.querySelector(".navbar-links");
	const desktopQuery = window.matchMedia("(min-width: 769px)");

	navbarToggle?.addEventListener("click", () => {
		const isOpen = navbarLinks?.classList.toggle("active") ?? false;
		navbarToggle?.classList.toggle("active");
		navbarToggle?.setAttribute("aria-expanded", String(isOpen));
	});

	// On desktop the links are always shown via CSS, so reset the toggle state
	// when crossing the breakpoint to keep aria-expanded from going stale.
	desktopQuery.addEventListener("change", (event) => {
		if (event.matches) {
			navbarLinks?.classList.remove("active");
			navbarToggle?.classList.remove("active");
			navbarToggle?.setAttribute("aria-expanded", "false");
		}
	});
</script>

<style lang="scss">
	.navbar-logo-text {
		font-family: Chicago, sans-serif;
		font-size: 22px;
		font-weight: 800;
		margin: 0;

		@media (max-width: 990px) {
			text-align: center;
		}
	}
	.text-gradient {
		background-image: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 400%;
		background-position: 0;
	}
	.navbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: var(--page-bg);
		color: rgb(var(--accent));
		padding: 10px;
	}

	.navbar-logo a {
		font-size: 24px;
		font-weight: bold;
		text-decoration: none;
		color: #fff;
	}

	.navbar-links {
		display: flex;
		justify-content: center;
		align-items: center;
		list-style: none;
		margin: 0;
		padding: 10px;
	}

	.navbar-links li {
		margin: 0 10px;
	}

	.navbar-links a {
		font-family: Chicago;
		font-size: 18px;
		text-decoration: none;
		color: rgb(var(--accent));
	}

	.navbar-toggle:focus-visible,
	.navbar-links a:focus-visible {
		outline: 2px solid var(--color-focus-outline);
		outline-offset: 2px;
		border-radius: 2px;
	}

	.navbar-toggle {
		display: none;
		cursor: pointer;
		appearance: none;
		background: none;
		border: none;
		padding: 0;
		margin: 0;
	}

	.navbar-toggle span {
		display: block;
		width: 30px;
		height: 3px;
		background-color: #da62c4;
		margin: 5px 0;
	}

	@media (max-width: 768px) {
		.navbar-links {
			display: none;
		}

		.navbar-toggle {
			display: block;
			margin-right: 0.5rem;
		}

		.navbar-toggle.active span:nth-child(2) {
			opacity: 0;
		}

		.navbar-toggle.active span:nth-child(1) {
			transform: rotate(45deg) translate(5px, 5px);
		}

		.navbar-toggle.active span:nth-child(3) {
			transform: rotate(-45deg) translate(5px, -5px);
		}

		.navbar-links.active {
			z-index: 1000;
			display: flex;
			flex-direction: column;
			align-items: center;
			position: absolute;
			top: 48px;
			left: 0;
			width: -webkit-fill-available;
			background-color: #e1e1e9;
		}

		.navbar-links.active li {
			margin: 10px 0;
			color: #da62c4;
		}
	}
</style>
